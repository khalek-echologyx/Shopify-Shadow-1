<div class="max-w-md">
  <div class="text-5xl font-bold my-4">{{ section.settings.title }}</div>
  <div class="my-4">
    <p class="text-base md:text-xl leading-normal">{{ section.settings.description }}</p>
  </div>
  <div class="my-4">
    {% if section.settings.button_link == blank %}
      {% assign shop_url = shop.secure_url %}
      {% else %}
      {% assign shop_url = section.settings.button_link %}
    {% endif %}
    <a href="{{ shop_url }}" class="px-4 py-2 bg-green-800 text-white rounded">{{ section.settings.button_label }}</a>
  </div>
</div>

{% schema %}
  {
    "name": "Template 404",
    "tag": "section",
    "class": "flex items-center justify-center text-center py-7 h-screen",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "default": "404 - Page Not Found",
        "label": "404 Heading Title"
      },
      {
        "type": "text",
        "id": "description",
        "default": "The page you are looking for does not exist.",
        "label": "404 Description"
      },
      {
        "type": "text",
        "id": "button_label",
        "default": "Go Back Home",
        "label": "404 Button Label"
      },
      {
        "type": "url",
        "id": "button_link",
        "default": "/",
        "label": "404 Button Link"
      }
    ]
  }
{% endschema %}