<div class="w-full py-6 px-3">
  <div class="border border-gray-200 bg-white shadow-lg rounded-lg overflow-hidden">
    <a href="{{ product.url }}">
      {% if product.featured_image %}
        <div class="h-80 overflow-hidden">
          <img
            src="{{ product.featured_image | img_url: 'medium' }}"
            alt="{{ product.featured_image.alt }}"
            width="300"
            height="300"
            class="w-full h-full object-cover "
          >
        </div>
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-100' }}
      {% endif %}
    </a>

    <div class="p-4">
      <span class="text-sm block">{{ product.vendor }}</span>

      <a class="text-gray-700 uppercase font-medium" href="{{ product.url }}">{{ product.title }}</a>

      <p class="text-gray-500">{{ product.price | money }}</p>
    </div>
  </div>
</div>
