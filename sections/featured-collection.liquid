
<div>Feature section</div>
{% for product in section.settings.featured_collection.products %}
    {% render 'product-cart', product:product%}
{% endfor %}

{% schema %}
{
  "name": "Feature Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Feature Collection",
      "label": "Title"
    },
    {
      "type": "collection",
      "id": "feature_collection",
      "label": "Collection"
    }
  ]
}
{% endschema %}
